# =============================================================================
# SitePilot Backend — Environment Variables
# Скопіюйте цей файл у .env і заповніть значення
# =============================================================================

# App
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sitepilot
DB_USER=postgres
DB_PASS=your_secure_password
DB_SSL=false
DB_SYNC=false
DB_LOGGING=true

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.solomiya-energy.com
